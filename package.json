{
  "name": "linter-todo",
  "description": "Scans files for TODO-style keywords and reports them as linter messages",
  "repository": "https://github.com/asiloisad/pulsar-linter-todo",
  "keywords": [
    "linter",
    "todo",
    "fixme",
    "hack",
    "note",
    "review",
    "bug"
  ],
  "version": "1.4.0",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0"
  },
  "main": "./lib/main",
  "activationHooks": [
    "core:loaded-shell-environment"
  ],
  "activationCommands": {
    "atom-workspace": [
      "linter-todo:toggle-state",
      "linter-todo:lint-projects",
      "linter-todo:lint-selected"
    ]
  },
  "consumedServices": {
    "linter-indie": {
      "versions": {
        "2.0.0": "consumeIndie"
      }
    },
    "atom-ide-busy-signal": {
      "versions": {
        "0.1.0": "consumeBusySignal"
      }
    },
    "tree-view": {
      "versions": {
        "^1.0.0": "consumeTreeView"
      }
    }
  },
  "providedServices": {
    "linter": {
      "versions": {
        "2.0.0": "provideLinter"
      }
    }
  },
  "linter-package": true,
  "configSchema": {
    "state": {
      "order": 1,
      "title": "Linter state",
      "description": "Enable or disable the service of linter.",
      "type": "boolean",
      "default": true
    },
    "keywords": {
      "order": 2,
      "title": "Keywords",
      "description": "List of TODO-style keywords to detect.",
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "TODO",
        "FIXME",
        "CHANGED",
        "XXX",
        "IDEA",
        "HACK",
        "NOTE",
        "REVIEW",
        "NB",
        "BUG",
        "QUESTION",
        "COMBAK",
        "TEMP",
        "DEBUG",
        "OPTIMIZE",
        "WARNING"
      ]
    }
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
