{
  "name": "linter-todo",
  "description": "Scans files for TODO-style keywords and reports them as linter messages",
  "repository": "https://github.com/asiloisad/pulsar-linter-todo",
  "keywords": [
    "linter",
    "todo",
    "fixme",
    "hack",
    "note",
    "review",
    "bug"
  ],
  "version": "1.0.0",
  "license": "MIT",
  "engines": {
    "atom": ">=1.100.0 <2.0.0"
  },
  "main": "./lib/main",
  "consumedServices": {
    "linter-indie": {
      "versions": {
        "2.0.0": "consumeIndie"
      }
    }
  },
  "providedServices": {
    "linter": {
      "versions": {
        "2.0.0": "provideLinter"
      }
    }
  },
  "linter-package": true,
  "configSchema": {
    "state": {
      "order": 1,
      "title": "Linter state",
      "description": "Enable or disable the service of linter.",
      "type": "boolean",
      "default": true
    },
    "extensions": {
      "order": 2,
      "title": "Project scan extensions",
      "description": "File extensions to include in project-wide scanning.",
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".py",
        ".ipy",
        ".rb",
        ".java",
        ".c",
        ".cpp",
        ".h",
        ".hpp",
        ".cs",
        ".go",
        ".rs",
        ".php",
        ".swift",
        ".kt",
        ".scala",
        ".sh",
        ".bash",
        ".zsh",
        ".ps1",
        ".bat",
        ".cmd",
        ".lua",
        ".r",
        ".m",
        ".sql",
        ".html",
        ".css",
        ".scss",
        ".less",
        ".xml",
        ".yaml",
        ".yml",
        ".toml",
        ".json",
        ".md",
        ".txt",
        ".rst",
        ".tex",
        ".cfg",
        ".ini",
        ".conf",
        ".vue",
        ".svelte",
        ".astro",
        ".ex",
        ".exs",
        ".erl",
        ".hs",
        ".ml",
        ".clj",
        ".el",
        ".vim",
        ".coffee",
        ".dart",
        ".pl",
        ".pm",
        ".cson",
        ".csm",
        ".dat",
        ".gra",
        ".grb"
      ]
    },
    "keywords": {
      "order": 3,
      "title": "Keywords",
      "description": "List of TODO-style keywords to detect.",
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "TODO",
        "FIXME",
        "CHANGED",
        "XXX",
        "IDEA",
        "HACK",
        "NOTE",
        "REVIEW",
        "NB",
        "BUG",
        "QUESTION",
        "COMBAK",
        "TEMP",
        "DEBUG",
        "OPTIMIZE",
        "WARNING"
      ]
    }
  }
}
